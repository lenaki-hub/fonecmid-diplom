#Область ПрограммныйИнтерфейс
////////////////////////////////////////////////////////////////////////////////
// Процедура ВКМ_УведомлениеТелеграм
//
// Назначение: Регламентное задание для отправки уведомлений в Telegram.
// Выбирает все сообщения из справочника ВКМ_УведомленияТелеграм,
// отправляет их через Telegram Bot API и удаляет успешно отправленные.
//
// Алгоритм работы:
// 1. Создаёт защищённое HTTPS-соединение с сервером api.telegram.org
// 2. Формирует HTTP-запрос для метода sendMessage с токеном бота
// 3. Выполняет запрос к справочнику уведомлений для получения всех записей
// 4. Для каждого уведомления:
//    - Формирует структуру с параметрами отправки (chat_id, text)
//    - Преобразует структуру в JSON и устанавливает как тело запроса
//    - Отправляет POST-запрос 
//    - Проверяет код ответа: 200 — успешно → удаляет уведомление
//    - Иначе — записывает ошибку в журнал регистрации
//
// Требования к константам:
// - ВКМ_ТелеграмБотТокен — токен бота, полученный от @BotFather
// - ВКМ_ТелеграмГруппаID — идентификатор чата/группы для отправки
//
// Журнал регистрации:
// - При ошибке отправки записывается тело ответа сервера
//
////////////////////////////////////////////////////////////////////////////////
Процедура ВКМ_УведомлениеТелеграм() Экспорт
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	
	Соединение = Новый HTTPСоединение("api.telegram.org", 443, , , , , ЗащищенноеСоединение);
	
	ЗапросНТТТР = Новый HTTPЗапрос("/bot" + Константы.ВКМ_ТелеграмБотТокен.Получить() + "/sendMessage");
	ЗапросНТТТР.Заголовки.Вставить("Content-Type", "application/json");
	
	 	Запрос = Новый Запрос;
	 	Запрос.Текст =
	 		"ВЫБРАТЬ
	 		|	ВКМ_УведомленияТелеграм.Ссылка КАК Ссылка,
	 		|	ВКМ_УведомленияТелеграм.ТекстСообщения КАК ТекстСообщения
	 		|ИЗ
	 		|	Справочник.ВКМ_УведомленияТелеграм КАК ВКМ_УведомленияТелеграм";
	 	
	 	РезультатЗапроса = Запрос.Выполнить();
	 	
	 	Выборка = РезультатЗапроса.Выбрать();
	 	
	 	Пока Выборка.Следующий() Цикл
	 		
	 		ПараметрыОтправления = Новый Структура;
	 		ПараметрыОтправления.Вставить("chat_id", Константы.ВКМ_ТелеграмГруппаID.Получить());
	 		ПараметрыОтправления.Вставить("text", Выборка.ТекстСообщения);
	 		
	 		ЗаписьJSON = Новый ЗаписьJSON;
	 		ЗаписьJSON.УстановитьСтроку();
	 		ЗаписатьJSON(ЗаписьJSON, ПараметрыОтправления);
	 		СтрокаJSON = ЗаписьJSON.Закрыть();
	 		
	 		ЗапросНТТТР.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	 		
	 		Ответ = Соединение.Получить(ЗапросНТТТР);
	 		
	 		Если Ответ.КодСостояния = 200 Тогда
	 			ЭлементУдаляем = Выборка.Ссылка.ПолучитьОбъект();
	 			ЭлементУдаляем.Удалить();
	 		Иначе
	 			ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	 			ЗаписьЖурналаРегистрации("ВКМ_ИнтеграцияСТелеграм", УровеньЖурналаРегистрации.Ошибка, , , ТелоОтвета);
	 		КонецЕсли;
	 		
	 	КонецЦикла;
	 	
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли